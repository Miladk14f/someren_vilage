@model IEnumerable<someren_vilage.Models.Activity>

@{
    ViewData["Title"] = "Activities";
}

<div class="page-header">
    <div class="page-header-overlay"></div>
    <h1 class="display-6">Activities</h1>
    <p>Plan, organize, and track all activities and participant sign-ups.</p>
</div>

@if (TempData["DeleteError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
        <strong>Error:</strong> @TempData["DeleteError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
        <strong>Error:</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="toolbar">
    <a asp-controller="Activity" asp-action="Create" class="btn btn-success shadow-sm">+ Create Activity</a>
    <div class="sort-bar ms-auto">
        <form method="get" class="d-flex align-items-center gap-2 mb-0">
            <label for="sortSelect" class="form-label mb-0 fw-semibold text-nowrap">Sort by:</label>
            <select id="sortSelect" name="sort" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                <option value="" selected="@(ViewData["CurrentSort"] == null ? "selected" : null)">Name</option>
                <option value="name_desc" selected="@(ViewData["CurrentSort"] as string == "name_desc" ? "selected" : null)">Name desc</option>
                <option value="day" selected="@(ViewData["CurrentSort"] as string == "day" ? "selected" : null)">Day</option>
                <option value="day_desc" selected="@(ViewData["CurrentSort"] as string == "day_desc" ? "selected" : null)">Day desc</option>
                <option value="time" selected="@(ViewData["CurrentSort"] as string == "time" ? "selected" : null)">Time</option>
                <option value="time_desc" selected="@(ViewData["CurrentSort"] as string == "time_desc" ? "selected" : null)">Time desc</option>
            </select>
        </form>
    </div>
</div>

@{ var hasAny = false; }

<div class="content-card">
    <table class="table table-styled table-hover mb-0">
        <thead>
            <tr>
                <th>Name</th>
                <th>Day</th>
                <th>Time</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    hasAny = true;
                    <tr>
                        <td class="fw-semibold">@item.Name</td>
                        <td><span class="badge bg-success">@item.Day</span></td>
                        <td>@item.TimeOfDay</td>
                        <td class="text-end text-nowrap">
                            <a asp-controller="Activity" asp-action="Participent" asp-route-id="@item.ActivityId" class="btn btn-sm btn-purple me-1">Participants</a>
                            <a asp-controller="Activity" asp-action="Supervisor" asp-route-id="@item.ActivityId" class="btn btn-sm btn-outline-info me-1">Supervisors</a>
                            <a asp-controller="Activity" asp-action="Edit" asp-route-id="@item.ActivityId" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <form asp-controller="Activity" asp-action="Delete" asp-route-id="@item.ActivityId" method="post" style="display:inline" onsubmit="return confirm('Delete this activity?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (!hasAny)
{
    <div class="content-card empty-state">
        <h5>No activities available</h5>
        <p class="mb-0">Create your first activity to get started.</p>
    </div>
}

@model IEnumerable<someren_vilage.Models.Activity>

@{
    ViewData["Title"] = "Activities";
}

<div class="d-flex align-items-center mb-3">
    <h2 class="m-0">All Activities</h2>
</div>

@if (TempData["DeleteError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Error:</strong> @TempData["DeleteError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Error:</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex align-items-center mb-3">
    <a asp-controller="Activity" asp-action="Create" class="btn btn-success me-2">Create Activity</a>
</div>

<form method="get" class="mb-3">
    <label for="sortSelect" class="form-label">Sort by:</label>
    <select id="sortSelect" name="sort" class="form-select w-auto d-inline-block me-2" onchange="this.form.submit()">
        <option value="" selected="@(ViewData["CurrentSort"] == null ? "selected" : null)">Name</option>
        <option value="name_desc" selected="@(ViewData["CurrentSort"] as string == "name_desc" ? "selected" : null)">Name desc</option>
        <option value="day" selected="@(ViewData["CurrentSort"] as string == "day" ? "selected" : null)">Day</option>
        <option value="day_desc" selected="@(ViewData["CurrentSort"] as string == "day_desc" ? "selected" : null)">Day desc</option>
        <option value="time" selected="@(ViewData["CurrentSort"] as string == "time" ? "selected" : null)">Time</option>
        <option value="time_desc" selected="@(ViewData["CurrentSort"] as string == "time_desc" ? "selected" : null)">Time desc</option>
    </select>
</form>

@{
    var hasAny = false;
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Day</th>
            <th>Time</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null)
        {
            foreach (var item in Model)
            {
                hasAny = true;
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Day</td>
                    <td>@item.TimeOfDay</td>
                    <td class="text-nowrap">
                        <a asp-controller="Activity" asp-action="Participent" asp-route-id="@item.ActivityId" class="btn btn-sm btn-purple me-1">Participants</a>
                        <a asp-controller="Activity" asp-action="Supervisor" asp-route-id="@item.ActivityId" class="btn btn-sm btn-outline-info me-1">Supervisors</a>

                        <a asp-controller="Activity" asp-action="Edit" asp-route-id="@item.ActivityId" class="btn btn-sm btn-primary me-1">Edit</a>

                        <form asp-controller="Activity" asp-action="Delete" asp-route-id="@item.ActivityId" method="post" style="display:inline" onsubmit="return confirm('Delete this activity?');">
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>

                </tr>
            }
        }
    </tbody>
</table>

@if (!hasAny)
{
    <div class="alert alert-info">No activities available.</div>
}

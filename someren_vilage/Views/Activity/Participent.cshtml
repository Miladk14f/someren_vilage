@model someren_vilage.ViewModels.ActivityParticipantsViewModel

@{
    ViewData["Title"] = "Participants";
}

<h2>Participants for @Model.Activity.Name</h2>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<h4>Students</h4>
<table class="table">
    <thead><tr><th>Number</th><th>Name</th><th></th></tr></thead>
    <tbody>
        @foreach (var s in Model.Participants)
        {
            <tr>
                <td>@s.StudentNumber</td>
                <td>@s.FirstName @s.LastName</td>
                <td class="text-nowrap">
                    <form asp-controller="Activity" asp-action="RemoveParticipant" method="post" style="display:inline">
                        <input type="hidden" name="activityId" value="@Model.Activity.ActivityId" />
                        <input type="hidden" name="studentNumber" value="@s.StudentNumber" />
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-danger" type="submit" onclick="return confirm('Remove participant?')">Remove</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<h5>Add student</h5>
<div class="row">
    <div class="col-md-6">
        <form asp-controller="Activity" asp-action="AddParticipant" method="post">
            <input type="hidden" name="activityId" value="@Model.Activity.ActivityId" />
            <div class="mb-3">
                <label class="form-label">Select Student</label>
                <select name="studentNumber" class="form-control">
                    <option value="">-- Select a Student --</option>
                    @foreach (var s in Model.AllStudents)
                    {
                        var assigned = Model.Participants.Any(p => p.StudentNumber == s.StudentNumber);
                        <option value="@s.StudentNumber" disabled="@(assigned ? "disabled" : null)">
                            @s.StudentNumber - @s.FirstName @s.LastName@(assigned ? " (assigned)" : "")
                        </option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Add</button>
            @Html.AntiForgeryToken()
        </form>
    </div>
</div>
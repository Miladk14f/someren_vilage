@model someren_vilage.Models.Activity

@{
    ViewData["Title"] = "Create Activity";
}

<div class="page-header">
    <div class="page-header-overlay"></div>
    <h1 class="display-6">Create Activity</h1>
    <p>Fill in the details below to add a new activity.</p>
</div>

<div class="content-card form-card">
    <form asp-controller="Activity" asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <div class="mb-3">
            <label class="form-label fw-semibold">Name</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Day</label>
            <select asp-for="Day" class="form-select">
                <option value="">-- Select Day --</option>
                <option value="Monday">Monday</option>
                <option value="Tuesday">Tuesday</option>
                <option value="Wednesday">Wednesday</option>
                <option value="Thursday">Thursday</option>
                <option value="Friday">Friday</option>
                <option value="Saturday">Saturday</option>
                <option value="Sunday">Sunday</option>
            </select>
        </div>
        <div class="mb-4">
            <label class="form-label fw-semibold">Time</label>
            <input asp-for="TimeOfDay" class="form-control" type="time" step="1" />
            <span asp-validation-for="TimeOfDay" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary shadow-sm">Create</button>
            <a asp-action="Index" class="btn btn-outline-secondary">&larr; Back to List</a>
        </div>
    </form>
</div>


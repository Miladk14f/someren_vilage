@model IEnumerable<someren_vilage.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<div class="page-header">
    <div class="page-header-overlay"></div>
    <h1 class="display-6">Orders</h1>
    <p>View and manage drink orders placed by students.</p>
</div>

<div class="toolbar">
    <a asp-controller="Order" asp-action="Create" class="btn btn-success shadow-sm">+ Create Order</a>
</div>

<div class="content-card">
    <table class="table table-styled table-hover mb-0">
        <thead>
            <tr>
                <th>Student</th>
                <th>Drink</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model)
            {
                <tr>
                    <td>@o.Student.FirstName @o.Student.LastName <span class="badge bg-secondary">@o.StudentNumber</span></td>
                    <td class="fw-semibold">@o.Drink.Name</td>
                    <td>@o.Drink.Price.ToString("C")</td>
                    <td>@o.Quantity</td>
                    <td class="fw-semibold">@((o.Drink.Price * o.Quantity).ToString("C"))</td>
                    <td class="text-end text-nowrap">
                        <form asp-controller="Order" asp-action="RemoveOrder" method="post" style="display:inline" onsubmit="return confirm('Remove this order?');">
                            <input type="hidden" name="studentNumber" value="@o.StudentNumber" />
                            <input type="hidden" name="drinkId" value="@o.DrinkId" />
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger" type="submit">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="content-card empty-state">
        <h5>No orders yet</h5>
        <p class="mb-0">Create your first order to get started.</p>
    </div>
}

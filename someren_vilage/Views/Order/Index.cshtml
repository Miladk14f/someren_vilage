@model IEnumerable<someren_vilage.Models.Order>

@{
    ViewData["Title"] = "Orders";
}

<div class="d-flex align-items-center mb-3">
    <h2 class="m-0">All Orders</h2>
</div>

<div class="d-flex align-items-center mb-3">
    <a asp-controller="Order" asp-action="Create" class="btn btn-success me-2">Create Order</a>
</div>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Student</th>
            <th>Drink</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Total</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>@o.Student.FirstName @o.Student.LastName (@o.StudentNumber)</td>
                <td>@o.Drink.Name</td>
                <td>@o.Drink.Price.ToString("C")</td>
                <td>@o.Quantity</td>
                <td>@((o.Drink.Price * o.Quantity).ToString("C"))</td>
                <td class="text-nowrap">
                    <form asp-controller="Order" asp-action="RemoveOrder" method="post" style="display:inline" onsubmit="return confirm('Remove this order?');">
                        <input type="hidden" name="studentNumber" value="@o.StudentNumber" />
                        <input type="hidden" name="drinkId" value="@o.DrinkId" />
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-danger" type="submit">Remove</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">No orders yet.</div>
}

@model someren_vilage.ViewModels.OrderViewModel

@{
    ViewData["Title"] = "Create Order";
}

<h2>Create Order</h2>

<form asp-controller="Order" asp-action="AddOrder" method="post">
    <div class="mb-3">
        <label class="form-label">Student</label>
        <select name="studentNumber" class="form-select">
            @foreach (var s in Model.AllStudents)
            {
                <option value="@s.StudentNumber">@s.StudentNumber - @s.FirstName @s.LastName</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Drink</label>
        <select name="drinkId" class="form-select">
            @foreach (var d in Model.AllDrinks)
            {
                <option value="@d.DrinkId">@d.Name - @d.Price.ToString("C")</option>
            }
        </select>
    </div>
    <div class="mb-3">
        <label class="form-label">Quantity</label>
        <input type="number" name="quantity" value="1" min="1" class="form-control" style="width:120px" />
    </div>
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-success">Create</button>
    <a asp-controller="Order" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

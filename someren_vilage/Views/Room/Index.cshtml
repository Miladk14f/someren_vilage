@model IEnumerable<someren_vilage.Models.Room>

@{
    ViewData["Title"] = "Rooms";
}

<div class="page-header">
    <div class="page-header-overlay"></div>
    <h1 class="display-6">Rooms</h1>
    <p>Manage all rooms, floors, buildings, and capacity across the village.</p>
</div>

@if (TempData["DeleteError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
        <strong>Error:</strong> @TempData["DeleteError"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="toolbar">
    <a asp-controller="Room" asp-action="Create" class="btn btn-success shadow-sm">+ Create Room</a>
    <div class="sort-bar ms-auto">
        <form method="get" class="d-flex align-items-center gap-2 mb-0">
            <label for="sortSelect" class="form-label mb-0 fw-semibold text-nowrap">Sort by:</label>
            <select id="sortSelect" name="sort" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                <option value="" selected="@(ViewData["CurrentSort"] == null ? "selected" : null)">Number</option>
                <option value="id_desc" selected="@(ViewData["CurrentSort"] as string == "id_desc" ? "selected" : null)">Number desc</option>
                <option value="floor" selected="@(ViewData["CurrentSort"] as string == "floor" ? "selected" : null)">Floor</option>
                <option value="floor_desc" selected="@(ViewData["CurrentSort"] as string == "floor_desc" ? "selected" : null)">Floor desc</option>
                <option value="type" selected="@(ViewData["CurrentSort"] as string == "type" ? "selected" : null)">Type</option>
                <option value="type_desc" selected="@(ViewData["CurrentSort"] as string == "type_desc" ? "selected" : null)">Type desc</option>
                <option value="capacity" selected="@(ViewData["CurrentSort"] as string == "capacity" ? "selected" : null)">Capacity</option>
                <option value="capacity_desc" selected="@(ViewData["CurrentSort"] as string == "capacity_desc" ? "selected" : null)">Capacity desc</option>
                <option value="building" selected="@(ViewData["CurrentSort"] as string == "building" ? "selected" : null)">Building</option>
                <option value="building_desc" selected="@(ViewData["CurrentSort"] as string == "building_desc" ? "selected" : null)">Building desc</option>
            </select>
        </form>
    </div>
</div>

@{ var hasAny = false; }

<div class="content-card">
    <table class="table table-styled table-hover mb-0">
        <thead>
            <tr>
                <th>Room Number</th>
                <th>Floor</th>
                <th>Type</th>
                <th>Capacity</th>
                <th>Building</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    hasAny = true;
                    <tr>
                        <td><span class="badge bg-primary">@item.RoomId</span></td>
                        <td>@item.Floor</td>
                        <td><span class="badge bg-info text-dark">@item.RoomType</span></td>
                        <td>@item.Capacity</td>
                        <td>@item.BuildingName</td>
                        <td class="text-end text-nowrap">
                            <a asp-controller="Room" asp-action="ManageStudents" asp-route-id="@item.RoomId" class="btn btn-sm btn-outline-info me-1">Manage</a>
                            <a asp-controller="Room" asp-action="Edit" asp-route-id="@item.RoomId" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <form asp-controller="Room" asp-action="Delete" asp-route-id="@item.RoomId" method="post" style="display:inline" onsubmit="return confirm('Delete this room?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (!hasAny)
{
    <div class="content-card empty-state">
        <h5>No rooms available</h5>
        <p class="mb-0">Add your first room to get started.</p>
    </div>
}

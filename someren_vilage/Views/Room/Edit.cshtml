@model someren_vilage.Models.Room

@{
    ViewData["Title"] = "Edit Room";
}

<div class="page-header">
    <div class="page-header-overlay"></div>
    <h1 class="display-6">Edit Room</h1>
    <p>Update the room details below.</p>
</div>

<div class="content-card form-card">
    <form asp-controller="Room" asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <input type="hidden" asp-for="RoomId" />
        <div class="mb-3">
            <label class="form-label fw-semibold">Floor</label>
            <input asp-for="Floor" class="form-control" type="number" />
            <span asp-validation-for="Floor" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Room Type</label>
            <select asp-for="RoomType" class="form-select">
                <option value="">-- Select Room Type --</option>
                <option value="single">Single</option>
                <option value="dormitory">Dormitory</option>
            </select>
            <span asp-validation-for="RoomType" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label fw-semibold">Capacity</label>
            <input asp-for="Capacity" class="form-control" type="number" />
            <span asp-validation-for="Capacity" class="text-danger"></span>
        </div>
        <div class="mb-4">
            <label class="form-label fw-semibold">Building</label>
            <select asp-for="BuildingName" class="form-select">
                <option value="">-- Select Building --</option>
                <option value="A">A</option>
                <option value="B">B</option>
            </select>
            <span asp-validation-for="BuildingName" class="text-danger"></span>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-primary shadow-sm">Save</button>
            <a asp-action="Index" class="btn btn-outline-secondary">&larr; Back to List</a>
        </div>
    </form>
</div>

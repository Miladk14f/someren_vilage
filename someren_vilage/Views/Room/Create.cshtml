@model someren_vilage.Models.Room

@{
    ViewData["Title"] = "Create Room";
}

<h2>Create Room</h2>

<form asp-controller="Room" asp-action="Create" method="post">
    @Html.AntiForgeryToken()
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    <div class="mb-3">
        <label class="form-label">Floor</label>
        <input asp-for="Floor" class="form-control" type="number" />
        <span asp-validation-for="Floor" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Room Type</label>
        <select asp-for="RoomType" class="form-select">
            <option value="">-- Select Room Type --</option>
            <option value="single">Single</option>
            <option value="dormitory">Dormitory</option>
        </select>
        <span asp-validation-for="RoomType" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Capacity</label>
        <input asp-for="Capacity" class="form-control" type="number" />
        <span asp-validation-for="Capacity" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Building</label>
        <select asp-for="BuildingName" class="form-select">
            <option value="">-- Select Building --</option>
            <option value="A">A</option>
            <option value="B">B</option>
        </select>
        <span asp-validation-for="BuildingName" class="text-danger"></span>
    </div>
    <button class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
</form>

@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<div class="hero-section text-center text-white py-5 mb-5 rounded-4 position-relative overflow-hidden">
    <div class="hero-overlay"></div>
    <div class="position-relative" style="z-index: 1;">
        <h1 class="display-3 fw-bold mb-3">Welcome to Someren Village</h1>
        <p class="lead fs-4 mb-4 mx-auto" style="max-width: 650px;">
            Your all-in-one management system for rooms, activities, students, lecturers, drinks &amp; orders.
        </p>
        <a asp-controller="Students" asp-action="Index" class="btn btn-light btn-lg px-4 me-2 shadow-sm">View Students</a>
        <a asp-controller="Room" asp-action="Index" class="btn btn-outline-light btn-lg px-4 shadow-sm">View Rooms</a>
    </div>
</div>

<!-- Quick Access Cards -->
<div class="row g-4 mb-5">
    <!-- Rooms -->
    <div class="col-lg-4 col-md-6">
        <div class="card h-100 border-0 shadow-sm card-hover">
            <div class="card-body text-center p-4">
                <div class="bg-primary bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M8.707 1.5a1 1 0 0 0-1.414 0L.646 8.146a.5.5 0 0 0 .708.708L2 8.207V13.5A1.5 1.5 0 0 0 3.5 15h9a1.5 1.5 0 0 0 1.5-1.5V8.207l.646.647a.5.5 0 0 0 .708-.708L13 5.793V2.5a.5.5 0 0 0-.5-.5h-1a.5.5 0 0 0-.5.5v1.293L8.707 1.5Z"/></svg>
                </div>
                <h4 class="fw-semibold mb-2">Rooms</h4>
                <p class="text-muted mb-3">Manage rooms, floors, buildings and capacity.</p>
                <a asp-controller="Room" asp-action="Index" class="btn btn-outline-primary">Go to Rooms &rarr;</a>
            </div>
        </div>
    </div>
    <!-- Activities -->
    <div class="col-lg-4 col-md-6">
        <div class="card h-100 border-0 shadow-sm card-hover">
            <div class="card-body text-center p-4">
                <div class="bg-success bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2h1V.5a.5.5 0 0 1 .5-.5ZM1 4v10a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V4H1Z"/></svg>
                </div>
                <h4 class="fw-semibold mb-2">Activities</h4>
                <p class="text-muted mb-3">Plan activities, assign participants &amp; supervisors.</p>
                <a asp-controller="Activity" asp-action="Index" class="btn btn-outline-success">Go to Activities &rarr;</a>
            </div>
        </div>
    </div>
    <!-- Students -->
    <div class="col-lg-4 col-md-6">
        <div class="card h-100 border-0 shadow-sm card-hover">
            <div class="card-body text-center p-4">
                <div class="bg-warning bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M15 14s1 0 1-1-1-4-5-4-5 3-5 4 1 1 1 1h8Zm-7.978-1A.261.261 0 0 1 7 12.996c.001-.264.167-1.03.76-1.72C8.312 10.629 9.282 10 11 10c1.717 0 2.687.63 3.24 1.276.593.69.758 1.457.76 1.72l-.008.002a.274.274 0 0 1-.014.002H7.022ZM11 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/></svg>
                </div>
                <h4 class="fw-semibold mb-2">Students</h4>
                <p class="text-muted mb-3">Browse records, manage enrolments and details.</p>
                <a asp-controller="Students" asp-action="Index" class="btn btn-outline-warning">Go to Students &rarr;</a>
            </div>
        </div>
    </div>
    <!-- Lecturers -->
    <div class="col-lg-4 col-md-6">
        <div class="card h-100 border-0 shadow-sm card-hover">
            <div class="card-body text-center p-4">
                <div class="bg-info bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0Zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4Z"/></svg>
                </div>
                <h4 class="fw-semibold mb-2">Lecturers</h4>
                <p class="text-muted mb-3">Manage lecturer profiles and room assignments.</p>
                <a asp-controller="Lecturer" asp-action="Index" class="btn btn-outline-info">Go to Lecturers &rarr;</a>
            </div>
        </div>
    </div>
    <!-- Drinks -->
    <div class="col-lg-4 col-md-6">
        <div class="card h-100 border-0 shadow-sm card-hover">
            <div class="card-body text-center p-4">
                <div class="bg-danger bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M8 16a6 6 0 0 0 6-6c0-1.655-1.122-2.904-2.432-4.362C10.254 4.176 8.75 2.503 8 0c-.75 2.503-2.254 4.176-3.568 5.638C3.122 7.096 2 8.345 2 10a6 6 0 0 0 6 6Z"/></svg>
                </div>
                <h4 class="fw-semibold mb-2">Drinks</h4>
                <p class="text-muted mb-3">Catalogue drinks, prices, stock &amp; VAT info.</p>
                <a asp-controller="Drink" asp-action="Index" class="btn btn-outline-danger">Go to Drinks &rarr;</a>
            </div>
        </div>
    </div>
    <!-- Orders -->
    <div class="col-lg-4 col-md-6">
        <div class="card h-100 border-0 shadow-sm card-hover">
            <div class="card-body text-center p-4">
                <div class="bg-secondary bg-gradient text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5ZM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4Zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4Z"/></svg>
                </div>
                <h4 class="fw-semibold mb-2">Orders</h4>
                <p class="text-muted mb-3">View and create drink orders for students.</p>
                <a asp-controller="Order" asp-action="Index" class="btn btn-outline-secondary">Go to Orders &rarr;</a>
            </div>
        </div>
    </div>
</div>

<!-- Info Banner -->
<div class="bg-light rounded-4 p-4 p-md-5 mb-4 text-center">
    <h3 class="fw-semibold mb-2">About Someren Village</h3>
    <p class="text-muted mx-auto mb-0" style="max-width: 700px;">
        Someren Village is a management platform built to streamline day-to-day operations.
        From assigning rooms and scheduling activities to managing student records &mdash;
        everything you need is just a click away.
    </p>
</div>

@model someren_vilage.Models.Drink

@{
    ViewData["Title"] = "Edit Drink";
}

<div class="page-header">
    <div class="page-header-overlay"></div>
    <h1 class="display-6">Edit Drink</h1>
    <p>Update the drink details below.</p>
</div>

<div class="content-card form-card">
    <form asp-controller="Drink" asp-action="Edit" method="post">
        <input type="hidden" asp-for="DrinkId" />
        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-semibold"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Price" class="form-label fw-semibold"></label>
            <input asp-for="Price" class="form-control" />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="VatPercentage" class="form-label fw-semibold">VAT %</label>
            <select asp-for="VatPercentage" class="form-select">
                <option value="9">9%</option>
                <option value="21">21%</option>
            </select>
            <span asp-validation-for="VatPercentage" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Stock" class="form-label fw-semibold"></label>
            <input asp-for="Stock" class="form-control" />
            <span asp-validation-for="Stock" class="text-danger"></span>
        </div>
        <div class="mb-4 form-check">
            <input asp-for="Alcoholic" class="form-check-input" />
            <label asp-for="Alcoholic" class="form-check-label fw-semibold"></label>
        </div>
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary shadow-sm">Save</button>
            <a asp-controller="Drink" asp-action="Index" class="btn btn-outline-secondary">&larr; Back to List</a>
        </div>
    </form>
</div>

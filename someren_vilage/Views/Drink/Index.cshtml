@model IEnumerable<someren_vilage.Models.Drink>

@{
    ViewData["Title"] = "Drinks";
}

<div class="page-header">
    <div class="page-header-overlay"></div>
    <h1 class="display-6">Drinks</h1>
    <p>Catalogue drinks, prices, stock &amp; VAT information.</p>
</div>

<div class="toolbar">
    <a asp-controller="Drink" asp-action="Create" class="btn btn-success shadow-sm">+ Create Drink</a>
    <div class="sort-bar ms-auto">
        <form method="get" class="d-flex align-items-center gap-2 mb-0">
            <label for="sortSelect" class="form-label mb-0 fw-semibold text-nowrap">Sort by:</label>
            <select id="sortSelect" name="sort" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                <option value="" selected="@(ViewData["CurrentSort"] == null ? "selected" : null)">Name</option>
                <option value="name_desc" selected="@(ViewData["CurrentSort"] as string == "name_desc" ? "selected" : null)">Name desc</option>
                <option value="price" selected="@(ViewData["CurrentSort"] as string == "price" ? "selected" : null)">Price</option>
                <option value="price_desc" selected="@(ViewData["CurrentSort"] as string == "price_desc" ? "selected" : null)">Price desc</option>
                <option value="stock" selected="@(ViewData["CurrentSort"] as string == "stock" ? "selected" : null)">Stock</option>
                <option value="stock_desc" selected="@(ViewData["CurrentSort"] as string == "stock_desc" ? "selected" : null)">Stock desc</option>
            </select>
        </form>
    </div>
</div>

<div class="content-card">
    <table class="table table-styled table-hover mb-0">
        <thead>
            <tr>
                <th>Name</th>
                <th>Price</th>
                <th>VAT %</th>
                <th>Stock</th>
                <th>Alcoholic</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold">@item.Name</td>
                    <td>@item.Price.ToString("C")</td>
                    <td>@item.VatPercentage%</td>
                    <td>@item.Stock</td>
                    <td>
                        @if (item.Alcoholic)
                        {
                            <span class="badge bg-danger">Yes</span>
                        }
                        else
                        {
                            <span class="badge bg-success">No</span>
                        }
                    </td>
                    <td class="text-end text-nowrap">
                        <a asp-controller="Drink" asp-action="Edit" asp-route-id="@item.DrinkId" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                        <form asp-controller="Drink" asp-action="Delete" asp-route-id="@item.DrinkId" method="post" style="display:inline" onsubmit="return confirm('Delete this drink?');">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <div class="content-card empty-state">
        <h5>No drinks available</h5>
        <p class="mb-0">Add your first drink to get started.</p>
    </div>
}

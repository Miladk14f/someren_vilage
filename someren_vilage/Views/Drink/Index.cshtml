@model IEnumerable<someren_vilage.Models.Drink>

@{
    ViewData["Title"] = "Drinks";
}

<div class="d-flex align-items-center mb-3">
    <h2 class="m-0">All Drinks</h2>
</div>

<div class="d-flex align-items-center mb-3">
    <a asp-controller="Drink" asp-action="Create" class="btn btn-success me-2">Create Drink</a>
</div>

<form method="get" class="mb-3">
    <label for="sortSelect" class="form-label">Sort by:</label>
    <select id="sortSelect" name="sort" class="form-select w-auto d-inline-block me-2" onchange="this.form.submit()">
        <option value="" selected="@(ViewData["CurrentSort"] == null ? "selected" : null)">Name</option>
        <option value="name_desc" selected="@(ViewData["CurrentSort"] as string == "name_desc" ? "selected" : null)">Name desc</option>
        <option value="price" selected="@(ViewData["CurrentSort"] as string == "price" ? "selected" : null)">Price</option>
        <option value="price_desc" selected="@(ViewData["CurrentSort"] as string == "price_desc" ? "selected" : null)">Price desc</option>
        <option value="stock" selected="@(ViewData["CurrentSort"] as string == "stock" ? "selected" : null)">Stock</option>
        <option value="stock_desc" selected="@(ViewData["CurrentSort"] as string == "stock_desc" ? "selected" : null)">Stock desc</option>
    </select>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price</th>
            <th>VAT %</th>
            <th>Stock</th>
            <th>Alcoholic</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price.ToString("C")</td>
                <td>@item.VatPercentage%</td>
                <td>@item.Stock</td>
                <td>@(item.Alcoholic ? "Yes" : "No")</td>
                <td class="text-nowrap">
                    <a asp-controller="Drink" asp-action="Edit" asp-route-id="@item.DrinkId" class="btn btn-sm btn-primary me-1">Edit</a>

                    <form asp-controller="Drink" asp-action="Delete" asp-route-id="@item.DrinkId" method="post" style="display:inline" onsubmit="return confirm('Delete this drink?');">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">No drinks available.</div>
}

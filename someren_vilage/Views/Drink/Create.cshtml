@model someren_vilage.Models.Drink

@{
    ViewData["Title"] = "Create Drink";
}

<h2>Create Drink</h2>

<form asp-controller="Drink" asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="VatPercentage" class="form-label">VAT %</label>
        <select asp-for="VatPercentage" class="form-select">
            <option value="9">9%</option>
            <option value="21">21%</option>
        </select>
        <span asp-validation-for="VatPercentage" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Stock" class="form-label"></label>
        <input asp-for="Stock" class="form-control" />
        <span asp-validation-for="Stock" class="text-danger"></span>
    </div>
    <div class="mb-3 form-check">
        <input asp-for="Alcoholic" class="form-check-input" />
        <label asp-for="Alcoholic" class="form-check-label"></label>
    </div>
    <button type="submit" class="btn btn-success">Create</button>
    <a asp-controller="Drink" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@model someren_vilage.Models.Student

<h2>Edit Student</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="StudentNumber" />

    <div class="mb-3">
        <label class="form-label">Student Number (Cannot change)</label>
        <input asp-for="StudentNumber" class="form-control" disabled />
    </div>

    <div class="mb-3">
        <label asp-for="FirstName" class="form-label"></label>
        <input asp-for="FirstName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="LastName" class="form-label"></label>
        <input asp-for="LastName" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="PhoneNumber" class="form-label"></label>
        <input asp-for="PhoneNumber" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Class" class="form-label"></label>
        <input asp-for="Class" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="RoomId" class="form-label">Room ID</label>
        <select asp-for="RoomId" class="form-control" asp-items="ViewBag.Rooms">
            <option value="">-- Select a Room --</option>
        </select>
        <span asp-validation-for="RoomId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Update Student</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
@model IEnumerable<someren_vilage.Models.Student>

@{
    ViewData["Title"] = "Students";
}

<div class="page-header">
    <div class="page-header-overlay"></div>
    <h1 class="display-6">Students</h1>
    <p>Browse student records, manage enrolments, and track details.</p>
</div>

<div class="toolbar">
    <a asp-controller="Students" asp-action="Create" class="btn btn-success shadow-sm">+ New Student</a>
    <div class="sort-bar ms-auto">
        <form method="get" class="d-flex align-items-center gap-2 mb-0">
            <label for="sortSelect" class="form-label mb-0 fw-semibold text-nowrap">Sort by:</label>
            <select id="sortSelect" name="sort" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                <option value="" selected="@(ViewData["CurrentSort"] == null ? "selected" : null)">Number</option>
                <option value="number_desc" selected="@(ViewData["CurrentSort"] as string == "number_desc" ? "selected" : null)">Number desc</option>
                <option value="firstname" selected="@(ViewData["CurrentSort"] as string == "firstname" ? "selected" : null)">First name</option>
                <option value="firstname_desc" selected="@(ViewData["CurrentSort"] as string == "firstname_desc" ? "selected" : null)">First name desc</option>
                <option value="lastname" selected="@(ViewData["CurrentSort"] as string == "lastname" ? "selected" : null)">Last name</option>
                <option value="lastname_desc" selected="@(ViewData["CurrentSort"] as string == "lastname_desc" ? "selected" : null)">Last name desc</option>
                <option value="phone" selected="@(ViewData["CurrentSort"] as string == "phone" ? "selected" : null)">Phone number</option>
                <option value="phone_desc" selected="@(ViewData["CurrentSort"] as string == "phone_desc" ? "selected" : null)">Phone number desc</option>
                <option value="class" selected="@(ViewData["CurrentSort"] as string == "class" ? "selected" : null)">Class</option>
                <option value="class_desc" selected="@(ViewData["CurrentSort"] as string == "class_desc" ? "selected" : null)">Class desc</option>
                <option value="room" selected="@(ViewData["CurrentSort"] as string == "room" ? "selected" : null)">Room</option>
                <option value="room_desc" selected="@(ViewData["CurrentSort"] as string == "room_desc" ? "selected" : null)">Room desc</option>
            </select>
        </form>
    </div>
</div>

@{ var hasAny = false; }

<div class="content-card">
    <table class="table table-styled table-hover mb-0">
        <thead>
            <tr>
                <th>Student Number</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Phone Number</th>
                <th>Class</th>
                <th>Room</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null)
            {
                foreach (var item in Model)
                {
                    hasAny = true;
                    <tr>
                        <td><span class="badge bg-secondary">@item.StudentNumber</span></td>
                        <td>@item.FirstName</td>
                        <td>@item.LastName</td>
                        <td>@item.PhoneNumber</td>
                        <td>@item.Class</td>
                        <td>@item.RoomId</td>
                        <td class="text-end text-nowrap">
                            <a asp-controller="Students" asp-action="Edit" asp-route-id="@item.StudentNumber" class="btn btn-sm btn-outline-primary me-1">Edit</a>
                            <form asp-controller="Students" asp-action="Delete" asp-route-id="@item.StudentNumber" method="post" style="display:inline" onsubmit="return confirm('Delete this student?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (!hasAny)
{
    <div class="content-card empty-state">
        <h5>No students available</h5>
        <p class="mb-0">Add your first student to get started.</p>
    </div>
}
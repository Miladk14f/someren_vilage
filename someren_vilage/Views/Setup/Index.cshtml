@model someren_vilage.Models.DatabaseSetupModel

@{
    ViewData["Title"] = "Database Setup";
}

<div class="page-header">
    <div class="page-header-overlay"></div>
    <h1 class="display-6">Database Setup</h1>
    <p>Configure your database connection to get started.</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
        <strong>Success:</strong> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="content-card form-card">
    <form asp-controller="Setup" asp-action="Index" method="post" id="setupForm">
        <input type="hidden" asp-for="InputMode" id="inputMode" />

        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <!-- Tabs -->
        <ul class="nav nav-tabs mb-4" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="properties-tab" data-bs-toggle="tab" data-bs-target="#properties-pane"
                        type="button" role="tab" aria-controls="properties-pane" aria-selected="true">
                    Connection Properties
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="connstring-tab" data-bs-toggle="tab" data-bs-target="#connstring-pane"
                        type="button" role="tab" aria-controls="connstring-pane" aria-selected="false">
                    Connection String
                </button>
            </li>
        </ul>

        <!-- Tab content -->
        <div class="tab-content">
            <!-- Connection Properties tab -->
            <div class="tab-pane fade show active" id="properties-pane" role="tabpanel" aria-labelledby="properties-tab">
                <div class="mb-3">
                    <label asp-for="Server" class="form-label fw-semibold"></label>
                    <input asp-for="Server" class="form-control" placeholder="e.g. someren-village.database.windows.net" />
                    <span asp-validation-for="Server" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Port" class="form-label fw-semibold"></label>
                    <input asp-for="Port" class="form-control" type="number" placeholder="1433" />
                    <span asp-validation-for="Port" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="UserId" class="form-label fw-semibold"></label>
                    <input asp-for="UserId" class="form-control" placeholder="e.g. ITB1_4" />
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <input asp-for="Password" class="form-control" type="password" placeholder="Enter password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Database" class="form-label fw-semibold"></label>
                    <input asp-for="Database" class="form-control" placeholder="e.g. someren_DB" />
                    <span asp-validation-for="Database" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Encrypt" class="form-label fw-semibold"></label>
                    <select asp-for="Encrypt" class="form-select">
                        <option value="Mandatory">Mandatory</option>
                        <option value="Optional">Optional</option>
                        <option value="Strict">Strict</option>
                    </select>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="TrustServerCertificate" class="form-check-input" type="checkbox" />
                    <label asp-for="TrustServerCertificate" class="form-check-label fw-semibold"></label>
                </div>
            </div>

            <!-- Connection String tab -->
            <div class="tab-pane fade" id="connstring-pane" role="tabpanel" aria-labelledby="connstring-tab">
                <div class="mb-3">
                    <label asp-for="ConnectionString" class="form-label fw-semibold"></label>
                    <textarea asp-for="ConnectionString" class="form-control font-monospace" rows="6"
                              placeholder="Paste your full connection string here..."></textarea>
                    <span asp-validation-for="ConnectionString" class="text-danger"></span>
                    <div class="form-text">
                        Example: <code>Data Source=tcp:server,1433;Initial Catalog=myDb;User ID=user;Password=pass;</code>
                    </div>
                </div>
            </div>
        </div>

        <hr class="section-divider" />

        <div class="d-flex justify-content-between">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary px-4">
                Connect
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        // Update InputMode hidden field when tabs are switched
        document.getElementById('properties-tab').addEventListener('shown.bs.tab', function () {
            document.getElementById('inputMode').value = 'properties';
        });
        document.getElementById('connstring-tab').addEventListener('shown.bs.tab', function () {
            document.getElementById('inputMode').value = 'connectionstring';
        });
    </script>
}

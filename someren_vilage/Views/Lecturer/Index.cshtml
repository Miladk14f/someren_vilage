@model List<someren_vilage.Models.Lecturer>
@{

}

<div class="text-center">
    <h1 class="display-4">Lecturers</h1>
    <p>all lecturers are showen here @Model.Count</p>
</div>

<a asp-action="Create" class="btn btn-success me-2" >New lecturer</a>

<table class="table table-striped">
    <thead>
        <tr>
            <th>first name</th>
            <th>last name</th>
            <th>phone number</th>
            <th>age</th>
            <th>room id</th>

            <td></td>
        </tr>
    </thead>

    <tbody>
        @{
            foreach (var Lecturer in Model)
            {
                <tr>
                    <td>@Lecturer.FirstName</td>
                    <td>@Lecturer.LastName</td>
                    <td>@Lecturer.PhoneNumber</td>
                    <td>@Lecturer.Age</td>
                    <td>@Lecturer.RoomId</td>


                    <td>
                        <a asp-action="Edit" asp-route-id="@Lecturer.FirstName" class="btn btn-sm btn-primary me-1">Edit</a>
                        <a asp-action="Delete" asp-route-id="@Lecturer.LecturerId" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>

            }
        }
    </tbody>
</table>



@model List<someren_vilage.Models.Lecturer>
@{

}

<div class="d-flex align-items-center mb-3">
    <h2 class="m-0">All Lecturer</h2>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <strong>Error:</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex align-items-center mb-3">
    <a asp-controller="Lecturer" asp-action="Create" class="btn btn-success me-2">New lecturer</a>
</div>

<form method="get" class="mb-3">
    <label for="sortSelect" class="form-label">Sort by:</label>
    <select id="sortSelect" name="sort" class="form-select w-auto d-inline-block me-2" onchange="this.form.submit()">
        <option value="" selected="@(ViewData["CurrentSort"] == null ? "selected" : null)">Last name</option>
        <option value="lastname_desc" selected="@(ViewData["CurrentSort"] as string == "lastname_desc" ? "selected" : null)">Last name desc</option>
        <option value="firstname" selected="@(ViewData["CurrentSort"] as string == "firstname" ? "selected" : null)">First name</option>
        <option value="firstname_desc" selected="@(ViewData["CurrentSort"] as string == "firstname_desc" ? "selected" : null)">First name desc</option>
        <option value="phone" selected="@(ViewData["CurrentSort"] as string == "phone" ? "selected" : null)">Phone number</option>
        <option value="phone_desc" selected="@(ViewData["CurrentSort"] as string == "phone_desc" ? "selected" : null)">Phone number desc</option>
        <option value="age" selected="@(ViewData["CurrentSort"] as string == "age" ? "selected" : null)">Age</option>
        <option value="age_desc" selected="@(ViewData["CurrentSort"] as string == "age_desc" ? "selected" : null)">Age desc</option>
        <option value="room" selected="@(ViewData["CurrentSort"] as string == "room" ? "selected" : null)">Room</option>
        <option value="room_desc" selected="@(ViewData["CurrentSort"] as string == "room_desc" ? "selected" : null)">Room desc</option>
    </select>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>first name</th>
            <th>last name</th>
            <th>phone number</th>
            <th>age</th>
            <th>room id</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var lecturer in Model)
        {
            <tr>
                <td>@lecturer.FirstName</td>
                <td>@lecturer.LastName</td>
                <td>@lecturer.PhoneNumber</td>
                <td>@lecturer.Age</td>
                <td>@lecturer.RoomId</td>
                <td class="text-nowrap">
                    <a asp-action="Edit" asp-route-id="@lecturer.LecturerId" class="btn btn-sm btn-primary me-1">Edit</a>

                    <form asp-controller="Lecturer" asp-action="Delete" asp-route-id="@lecturer.LecturerId" method="post" style="display:inline" onsubmit="return confirm('Delete this lecturer?');">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>


